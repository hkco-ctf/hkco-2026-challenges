service app
{
    disable = no
    socket_type = stream
    protocol = tcp
    wait = no
    type = UNLISTED
    bind = 0.0.0.0
    port = 1337
    log_type = FILE /proc/1/fd/1
    log_on_success = HOST PID DURATION EXIT
    log_on_failure = HOST ATTEMPT
    user = hkco2026

    # The binary and args to use
    server = /usr/bin/python3.12
    server_args = -u /home/hkco2026/chal.py

    # the maximum instances of this service per source IP address
    per_source = 5
}